# Contact form - Formspree
# Get your form ID at https://formspree.io
# Without this, the contact form falls back to mailto:
NEXT_PUBLIC_FORMSPREE_ID=xqeybove

# Analytics - Plausible (privacy-first, no cookies needed)
# Set to your domain to enable (e.g., joulebridge.com)
# Without this, no analytics script is loaded
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=joulebridge.com
