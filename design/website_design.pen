          ],
          "children": [
            {
              "type": "frame",
              "id": "AZcAJ",
              "name": "fullLandingHeroTextA",
              "width": 620,
              "height": 840,
              "layout": "vertical",
              "gap": 20,
              "children": [
                {
                  "type": "text",
                  "id": "SsSXH",
                  "name": "heroBadgeC",
                  "fill": "#4DD7C8",
                  "content": "VERIFIED DATA INFRASTRUCTURE FOR ENERGY",
                  "fontFamily": "IBM Plex Mono",
                  "fontSize": 15,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "VHg1I",
                  "name": "heroTitleC",
                  "fill": "#F7F8FA",
                  "content": "Make critical\nenergy records\neasier to trust.",
                  "fontFamily": "Manrope",
                  "fontSize": 68,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "tPc3t",
                  "name": "heroCopyC",
                  "fill": "#96A0AD",
                  "content": "JouleBridge helps utilities, AMISPs, C&I operators,\nand EV platforms turn raw telemetry into deterministic\nrecords, cryptographic proofs, and audit-ready evidence\nbefore disputes and reconciliation delays spread\nthrough the stack.",
                  "fontFamily": "Manrope",
                  "fontSize": 18,
                  "fontWeight": "500"
                },
                {
                  "type": "text",
                  "id": "qoJ7t",
                  "name": "heroChipsC",
                  "fill": "#F7F8FA",
                  "content": "EDGE RUNTIME     PROOF ENGINE     POLICY GATE     OPERATOR REVIEW",
                  "fontFamily": "IBM Plex Mono",
                  "fontSize": 12,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "CDA1w",
                  "name": "heroButtonsE",
                  "fill": "#4DD7C8",
                  "content": "START A PILOT",
                  "fontFamily": "IBM Plex Mono",
                  "fontSize": 18,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "U82vr",
                  "name": "heroButtonsF",
                  "fill": "#F7F8FA",
                  "content": "EXPLORE THE PLATFORM",
                  "fontFamily": "IBM Plex Mono",
                  "fontSize": 18,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "mWkB2",
                  "name": "heroFactsF",
                  "fill": "#F7F8FA",
                  "content": "Current baseline:\ndeterministic runtime, proofs, ledger, policy,\nand controlled sync.\n\nBest fit now:\npilots, audits, and high-trust telemetry workflows\nin energy operations.",
                  "lineHeight": 1.6,
                  "fontFamily": "Manrope",
                  "fontSize": 16,
